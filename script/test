#!/bin/bash
cd "$(dirname "$0")/.."

if [ -f .env ]; then
    source .env
fi

export JAVA_HOME
export ANDROID_HOME

if [ "$1" = "--prod" ]; then
    variant="ProdDebug"
    shift
elif [ "$1" = "--debug" ]; then
    variant="DevDebug"
    shift
else
    variant="DevDebug"
fi

if [ -n "$1" ]; then
    ./gradlew test${variant}UnitTest --tests "$1"
else
    ./gradlew test${variant}UnitTest
fi
test_result=$?

echo ""
echo "Test Results:"
echo "============"

total=0
passed=0
failed=0
skipped=0

for xml in app/build/test-results/test${variant}UnitTest/*.xml; do
    if [ -f "$xml" ]; then
        tests=$(grep -oP '(?<=tests=")[^"]+' "$xml" | head -1)
        failures=$(grep -oP '(?<=failures=")[^"]+' "$xml" | head -1)
        skipped_count=$(grep -oP '(?<=skipped=")[^"]+' "$xml" | head -1)
        
        [ -z "$tests" ] && tests=0
        [ -z "$failures" ] && failures=0
        [ -z "$skipped_count" ] && skipped_count=0
        
        total=$((total + tests))
        passed=$((passed + tests - failures - skipped_count))
        failed=$((failed + failures))
        skipped=$((skipped + skipped_count))
    fi
done

echo "Tests:  $total"
echo "Passed: $passed"
echo "Failed: $failed"
echo "Skipped: $skipped"

exit $test_result
